---
interface Props {
  date: Date;
}

const { date } = Astro.props;

const formattedDate = new Intl.DateTimeFormat("en-GB", {
  day: "numeric",
  month: "long",
  year: "numeric",
}).format(date);
---

<p class="dateline">{formattedDate}</p>

<style>
  .dateline {
    font-size: 0.72rem;
    font-weight: 700;
    font-family: var(--font-sans);
    letter-spacing: 0.1em;
    color: var(--color-muted);
    text-transform: uppercase;
  }
</style>
