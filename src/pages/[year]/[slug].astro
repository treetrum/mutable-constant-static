---
import { getCollection, render, type CollectionEntry } from "astro:content";
import Container from "../../components/Container.astro";
import DateLine from "../../components/DateLine.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { siteMeta } from "../../config/site";
import { getPostSlug } from "../../utils/posts";

interface Props {
  post: CollectionEntry<"posts">;
}

export async function getStaticPaths() {
  const posts = await getCollection("posts");

  return posts.map((post: CollectionEntry<"posts">) => ({
    params: {
      year: post.data.date.getFullYear().toString(),
      slug: post.data.slug,
    },
    props: {
      post,
    },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const postUrl = new URL(getPostSlug(post), Astro.site).toString();
const title = `${post.data.title} - ${siteMeta.title}`;
---

<BaseLayout title={title} description={siteMeta.description}>
  <Fragment slot="head">
    <link rel="canonical" href={postUrl} />
  </Fragment>
  <div class="page-content">
    <article>
      <Container>
        <h2 class="post-title">{post.data.title}</h2>
        <DateLine date={post.data.date} />
        <div class="rte">
          <Content />
        </div>
      </Container>
    </article>
  </div>
</BaseLayout>

<style>
  .page-content {
    padding: 40px 0;
  }

  .post-title {
    margin-bottom: 0.55rem;
    font-size: 2rem;
  }

  .rte {
    :global(p) {
      margin: 1.5rem 0;
      color: #1c1c1c;
    }

    :global(blockquote) {
      margin: 0;
      padding: 0.75rem 1.25rem;
      border-left: 3px solid #222222;
      background-color: #f8f8f8;
      border-radius: 0 var(--radius-medium) var(--radius-medium) 0;

      :global(p) {
        margin: 0;
        font-size: 1rem;
      }
    }

    :global(a) {
      text-decoration: underline;
    }

    :global(img) {
      max-width: 100%;
    }

    :global(pre) {
      padding: 1rem;
      margin: 1rem 0;
      font-size: 13px;
      line-height: 1.5;
      border: 1px solid #e0e0e0;
      border-radius: 8px;
    }

    :global(p) :global(code) {
      font-size: 0.9em;
      background-color: #f5f5f5;
      padding: 0.2rem;
      border-radius: 4px;
    }

    :global(.widescreen-embed) {
      aspect-ratio: 16 / 9;
      width: 100%;

      :global(iframe) {
        width: 100%;
        height: 100%;
      }
    }
  }
</style>
