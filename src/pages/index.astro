---
import { getCollection } from "astro:content";
import Container from "../components/Container.astro";
import DateLine from "../components/DateLine.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import {
  getPostExcerpt,
  getPostSlug,
  sortPostsByDateDesc,
} from "../utils/posts";

const posts = sortPostsByDateDesc(await getCollection("posts"));
---

<BaseLayout>
  <div class="posts-list">
    <Container>
      <div class="posts">
        {
          posts.map((post, index) => (
            <>
              <article class="post-snippet">
                <h3 class="title">
                  <a href={getPostSlug(post)}>{post.data.title}</a>
                </h3>
                <p class="snippet">{getPostExcerpt(post.body ?? "")}</p>
                <DateLine date={post.data.date} />
              </article>
              {index < posts.length - 1 && <hr class="post-separator" />}
            </>
          ))
        }
      </div>
    </Container>
  </div>
</BaseLayout>

<style>
  .posts-list {
    margin: 48px 0;
  }

  .posts {
    display: flex;
    flex-direction: column;
    gap: 32px;

    article {
      padding: 0;
    }
  }

  .post-separator {
    width: 100%;
    margin: 0;
    border: 0;
    border-top: 1px solid var(--color-line);
  }

  .title {
    margin-bottom: 0.45rem;
  }

  .snippet {
    margin-bottom: 0.65rem;
    color: var(--color-muted);
  }
</style>
